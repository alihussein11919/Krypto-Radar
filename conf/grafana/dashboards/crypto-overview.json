      "targets": [
        {
          "datasource": { "type": "trino-datasource", "uid": "" },
          "rawSql": "SELECT\n  CAST(f.date AS TIMESTAMP) AS time,\n  f.price_usd AS \"Bitcoin\",\n  f2.price_usd AS \"Ethereum\",\n  f3.price_usd AS \"Solana\"\nFROM fact_daily_prices f\nLEFT JOIN fact_daily_prices f2 ON f.date = f2.date AND f2.coin_id = 'ethereum'\nLEFT JOIN fact_daily_prices f3 ON f.date = f3.date AND f3.coin_id = 'solana'\nWHERE f.coin_id = 'bitcoin'\nORDER BY f.date\n",
